{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the hospital system (patient, doctor, or admin).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "description": "Email address" },
        "role": { "type": "string", "enum": ["patient", "doctor", "admin"], "description": "User role" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Department": {
      "title": "Department",
      "description": "A medical department in the hospital.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["name", "description"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "A doctor working in the hospital.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string", "description": "Reference to the User document" },
        "name": { "type": "string" },
        "departmentId": { "type": "string" },
        "specialty": { "type": "string" },
        "experience": { "type": "number" },
        "photoURL": { "type": "string" },
        "about": { "type": "string" }
      },
      "required": ["userId", "name", "departmentId", "specialty"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A medical appointment.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "patientName": { "type": "string" },
        "doctorId": { "type": "string" },
        "doctorName": { "type": "string" },
        "departmentName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "doctorId", "date", "time", "status", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "A medical report for a patient.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "title": { "type": "string" },
        "fileUrl": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "uploadedBy": { "type": "string" }
      },
      "required": ["patientId", "title", "fileUrl", "date", "uploadedBy"]
    },
    "BookedSlot": {
      "title": "BookedSlot",
      "description": "A booked time slot for a doctor to check availability without exposing PII.",
      "type": "object",
      "properties": {
        "doctorId": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" }
      },
      "required": ["doctorId", "date", "time"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/departments/{departmentId}": {
      "schema": { "$ref": "#/entities/Department" },
      "description": "Stores hospital departments."
    },
    "/doctors/{doctorId}": {
      "schema": { "$ref": "#/entities/Doctor" },
      "description": "Stores doctor profiles."
    },
    "/appointments/{appointmentId}": {
      "schema": { "$ref": "#/entities/Appointment" },
      "description": "Stores appointments."
    },
    "/reports/{reportId}": {
      "schema": { "$ref": "#/entities/Report" },
      "description": "Stores medical reports."
    },
    "/booked_slots/{slotId}": {
      "schema": { "$ref": "#/entities/BookedSlot" },
      "description": "Stores booked slots for availability checking."
    }
  }
}
